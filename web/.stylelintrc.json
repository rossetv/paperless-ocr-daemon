{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "color-no-invalid-hex": true,
    "color-named": "never",
    "declaration-property-value-disallowed-list": {
      "/^(color|background-color|border-color|outline-color|fill|stroke|box-shadow|text-shadow)/": [
        "/^#/",
        "/^rgb/",
        "/^hsl/"
      ]
    }
  },
  "overrides": [
    {
      "files": ["src/styles/tokens.css", "src/styles/themes.css", "src/styles/global.css"],
      "rules": {
        "color-named": null,
        "declaration-property-value-disallowed-list": null
      }
    }
  ]
}
